# ============================================================
# NiftyMind — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ────────────────────────────────────────────────────────────
# LLM PROVIDERS
# NiftyMind uses a tiered model strategy:
#   Tier 1 (Analysis agents 1-7): Gemini 3 Flash — fast, cheap
#   Tier 2 (Decision agents 9-10): Claude Sonnet + Extended Thinking
# ────────────────────────────────────────────────────────────

# Anthropic (Claude) — Required for decision agents (intraday + BTST)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini — Required for analysis agents (default provider)
GEMINI_API_KEY=AIzaSy...

# ── Analysis Agents (options_chain, sentiment, news, macro, order_flow, etc.) ──
# Provider: gemini (default, fastest + cheapest) | claude
ANALYSIS_LLM_PROVIDER=gemini

# Model for analysis agents
# Gemini options:  gemini-3-flash-preview  (fast, $0.50/$3 per 1M tokens)
# Claude options:  claude-haiku-4-5-20251001  (fast, $0.80/$4 per 1M tokens)
ANALYSIS_LLM_MODEL=gemini-3-flash-preview

# ── Decision Agents (intraday_decision, btst_decision) ──
# Provider: claude (default, best JSON reliability + Extended Thinking) | gemini
DECISION_LLM_PROVIDER=claude

# Model for decision agents
# Claude options:  claude-sonnet-4-20250514  (Extended Thinking, best accuracy)
# Gemini options:  gemini-3.1-pro-preview    (thinking_level=HIGH)
DECISION_LLM_MODEL=claude-sonnet-4-20250514

# Extended Thinking budget in tokens (decision agents only)
# 8000 = ~3-4 pages of internal reasoning per decision. Min: 1024, Max: 32000.
THINKING_BUDGET_TOKENS=8000

# ────────────────────────────────────────────────────────────
# DATABASE
# PostgreSQL with pgvector extension (for RAG knowledge base)
# ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/niftymind

# ────────────────────────────────────────────────────────────
# REDIS (inter-agent pub/sub message broker)
# ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────
# RAG SYSTEM
# Set RAG_ENABLED=false to bypass the knowledge base (testing)
# Run `python backend/rag/knowledge_builder.py` once to populate.
# ────────────────────────────────────────────────────────────
RAG_ENABLED=true

# ────────────────────────────────────────────────────────────
# NSE DATA FEEDS
# ────────────────────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# ────────────────────────────────────────────────────────────
# MISC
# ────────────────────────────────────────────────────────────
# Maximum tokens per LLM response (for analysis agents)
LLM_MAX_TOKENS=4096

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
