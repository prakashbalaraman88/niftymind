# === Zerodha Kite Connect ===
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# === TrueData Market Data API ===
TRUEDATA_USERNAME=
TRUEDATA_PASSWORD=

# === OpenRouter LLM API (OpenAI-compatible) ===
OPENROUTER_API_KEY=
# Analysis-tier model (fast/cheap). Flash-Lite chosen via scripts/llm_model_bench.py:
# fastest (~2s) at equal reliability/sanity and same price as Gemma.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Decision-tier model for intraday/BTST synthesis (blank = same as OPENROUTER_MODEL).
# Candidate upgrade (better calibration on chop, slower) — validate on real P&L first:
#   OPENROUTER_MODEL_DECISION=deepseek/deepseek-v3.2
OPENROUTER_MODEL_DECISION=
# Comma-separated failover chain, tried in order on 429/5xx/parse-failure.
# Paid then free Gemma, so a Flash-Lite outage degrades gracefully (never hard-stops).
OPENROUTER_FALLBACK_MODELS=google/gemma-4-31b-it,google/gemma-4-31b-it:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Supabase ===
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# === Database (Supabase PostgreSQL direct connection) ===
DATABASE_URL=

# === Redis (Upstash with TLS) ===
REDIS_URL=

# === Trading Configuration ===
TRADING_MODE=paper
TRADING_INSTRUMENTS=NIFTY,BANKNIFTY
TRADING_CAPITAL=100000
CONSENSUS_THRESHOLD=0.65
LIVE_TRADING_PIN=1952

# === Risk Limits ===
MAX_DAILY_LOSS=5000
MAX_TRADE_RISK_PCT=2.0
MAX_OPEN_POSITIONS=2
VIX_HALT_THRESHOLD=25.0
WEEKLY_LOSS_PCT=10.0
